{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "jsx": "react-jsx",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "allowJs": true,
    "allowImportingTsExtensions": true,

    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "isolatedModules": true,
    "skipLibCheck": true,

    "noEmit": true
  },

  "include": [
    "src",
    "*.ts",
    "*.tsx",
    "server.ts",
    "vite.config.ts"
  ]
}